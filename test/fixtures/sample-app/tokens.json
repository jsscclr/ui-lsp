{
  "colors": {
    "$type": "color",
    "primary": { "$value": "#1a73e8", "$description": "Primary brand color" },
    "secondary": { "$value": "#f50057", "$description": "Secondary accent color" },
    "text": {
      "default": { "$value": "#1a1a2e", "$description": "Default text color" },
      "muted": { "$value": "#555555", "$description": "Muted text color" }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": { "$value": "4px" },
    "small": { "$value": "8px" },
    "medium": { "$value": "16px" },
    "large": { "$value": "20px" },
    "xl": { "$value": "24px" }
  },
  "radii": {
    "$type": "dimension",
    "default": { "$value": "8px", "$description": "Default border radius" }
  },
  "fontWeights": {
    "$type": "fontWeight",
    "bold": { "$value": 700 }
  }
}
